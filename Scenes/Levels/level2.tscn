[sub_resource type="GDScript" id="GDScript_0r2a7"]
script/source = "extends Panel

signal retry_pressed
signal menu_pressed
signal close_pressed

@onready var title_label = $CenterContainer/MainPanel/MarginContainer/VBoxContainer/TitleLabel
@onready var message_label = $CenterContainer/MainPanel/MarginContainer/VBoxContainer/MessageLabel

@onready var btn_iq = $CenterContainer/MainPanel/MarginContainer/VBoxContainer/BtnIQ
@onready var btn_oq = $CenterContainer/MainPanel/MarginContainer/VBoxContainer/BtnOQ
@onready var btn_pq = $CenterContainer/MainPanel/MarginContainer/VBoxContainer/BtnPQ

func _ready() -> void:
	hide()
	process_mode = Node.PROCESS_MODE_ALWAYS

	btn_iq.pressed.connect(_on_retry_pressed)
	btn_oq.pressed.connect(_on_menu_pressed)
	btn_pq.pressed.connect(_on_close_pressed)

func mostrar_validacion(title: String, message: String) -> void:
	title_label.text = title
	message_label.text = message

	btn_iq.text = \"Retry\"
	btn_oq.text = \"Menu\"
	btn_pq.text = \"Close\"

	show()

func mostrar_game_over(message: String) -> void:
	mostrar_validacion(\"GAME OVER\", message)

func mostrar_exito(message: String) -> void:
	title_label.text = \"SUCCESS\"
	message_label.text = message

	btn_iq.text = \"Continue\"
	btn_oq.text = \"Menu\"
	btn_pq.text = \"Close\"

	show()

func _on_retry_pressed() -> void:
	hide()
	retry_pressed.emit()
	get_tree().reload_current_scene()

func _on_menu_pressed() -> void:
	hide()
	menu_pressed.emit()
	get_tree().change_scene_to_file(\"res://Scenes/Menu/menu.tscn\")

func _on_close_pressed() -> void:
	hide()
	close_pressed.emit()"

